<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Hirely</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Hirely" />
  <Description DefaultValue="Save the sender of this email straight into your Hirely CRM pipeline." />
  <IconUrl DefaultValue="https://hirely-ten-rho.vercel.app/outlook/icons/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://hirely-ten-rho.vercel.app/outlook/icons/icon-80.png" />
  <SupportUrl DefaultValue="https://hirelypro.com" />

  <AppDomains>
    <AppDomain>https://hirely-ten-rho.vercel.app</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://hirely-ten-rho.vercel.app/outlook/taskpane.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url" />

          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="Hirely.Group">
                <Label resid="Hirely.Group.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="Hirely.TaskpaneButton">
                  <Label resid="Hirely.TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="Hirely.TaskpaneButton.Label" />
                    <Description resid="Hirely.TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://hirely-ten-rho.vercel.app/outlook/icons/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://hirely-ten-rho.vercel.app/outlook/icons/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://hirely-ten-rho.vercel.app/outlook/icons/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://hirely-ten-rho.vercel.app/outlook/taskpane.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://hirely-ten-rho.vercel.app/outlook/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="Hirely.Group.Label" DefaultValue="Hirely" />
        <bt:String id="Hirely.TaskpaneButton.Label" DefaultValue="Save to Hirely" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="Hirely.TaskpaneButton.Tooltip" DefaultValue="Save this sender to your Hirely CRM pipeline." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
